{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["/home/chunchoc/.local/bin/context7-mcp"],
      "enabled": true
    },
    "magic": {
      "type": "local",
      "command": ["/home/chunchoc/.local/bin/magic-mcp"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["/home/chunchoc/.local/bin/chrome-devtools-mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -fr /": "deny",
      "rm -fr /*": "deny",
      "sudo rm -rf /": "deny",
      "sudo rm -rf /*": "deny",
      "sudo rm -fr /": "deny",
      "sudo rm -fr /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/": "deny",
      "rm -rf ~/*": "deny",
      "rm -fr ~": "deny",
      "rm -fr ~/": "deny",
      "rm -fr ~/*": "deny",
      "sudo rm -rf ~": "deny",
      "sudo rm -rf ~/": "deny",
      "sudo rm -rf ~/*": "deny",
      "sudo rm -fr ~": "deny",
      "sudo rm -fr ~/": "deny",
      "sudo rm -fr ~/*": "deny",
      "rm -rf $HOME": "deny",
      "rm -rf $HOME/": "deny",
      "rm -rf $HOME/*": "deny",
      "rm -fr $HOME": "deny",
      "rm -fr $HOME/": "deny",
      "rm -fr $HOME/*": "deny",
      "sudo rm -rf $HOME": "deny",
      "sudo rm -rf $HOME/": "deny",
      "sudo rm -rf $HOME/*": "deny",
      "sudo rm -fr $HOME": "deny",
      "sudo rm -fr $HOME/": "deny",
      "sudo rm -fr $HOME/*": "deny"
    },
    "read": {
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "~/Dotfiles/.secrets/**": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/credentials": "deny",
      "~/.config/gh/hosts.yml": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "~/.gnupg/**": "deny",
      "~/.pki/**": "deny",
      "~/.local/share/keyrings/**": "deny"
    },
    "edit": {
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "~/Dotfiles/.secrets/**": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/credentials": "deny",
      "~/.config/gh/hosts.yml": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "~/.gnupg/**": "deny",
      "~/.pki/**": "deny",
      "~/.local/share/keyrings/**": "deny"
    },
    "external_directory": {
      "~/Dotfiles/.secrets/**": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.config/gh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.pki/**": "deny",
      "~/.local/share/keyrings/**": "deny"
    }
  }
}
